<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- EXISTING PERMISSIONS -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />

    <!-- Camera is functionally required, but declared optional so the app
         can still install on Chrome OS / non-camera form factors and fail
         gracefully at runtime. Pairs with the CAMERA permission above and
         clears the PermissionImpliesUnsupportedChromeOsHardware lint. -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- NEW BACKGROUND RECORDING PERMISSIONS -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- Phase 4.3 (ADR-0017): recovery merge runs the FGS in dataSync mode
         on API 34+ (no camera/mic for muxer-only work). Required to declare
         this permission alongside the manifest's dataSync foregroundServiceType. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Phase 1.2 (ADR 0001): exact-alarm opt-in path. Inexact fallback
         remains always-supported via setAndAllowWhileIdle when
         canScheduleExactAlarms() returns false at runtime. USE_EXACT_ALARM
         is intentionally NOT declared — Play policy restricts it to
         calendar/alarm-clock/timer apps. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
                     android:minSdkVersion="31" />

    <!-- ADR-0027: re-arm the daily-window alarms after reboot / app replace.
         The boot receiver ONLY re-arms — it never starts the camera FGS. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".RovaApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Rova"
        tools:targetApi="31">
        
        <!-- MAIN ACTIVITY -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- PREVIEW ACTIVITY -->
        <activity 
            android:name=".ui.PreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.Rova"
            android:screenOrientation="unspecified" />
        
        <!-- BACKGROUND SERVICE -->
        <service
            android:name=".service.RovaRecordingService"
            android:foregroundServiceType="camera|microphone|dataSync"
            android:exported="false" />

        <!-- Phase 1.2: alarm tick receiver. exported=false so only the OS
             AlarmManager (which holds the same UID) can deliver to it. The
             intent-filter constrains by action+data scheme; PendingIntent
             identity uses Intent.data = rova://tick/<sessionId>. -->
        <receiver
            android:name=".service.RovaTickReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.aritr.rova.action.TICK" />
                <data android:scheme="rova" />
            </intent-filter>
        </receiver>

        <!-- Phase 1.3: cooperative-stop receiver. exported=false so only
             same-UID senders (notification PendingIntent + UI sendBroadcast)
             can deliver. PendingIntent identity uses
             Intent.data = rova://stop/<sessionId> so per-session stops do
             not collide with each other or with tick PIs. -->
        <receiver
            android:name=".service.RovaStopReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.aritr.rova.action.STOP" />
                <data android:scheme="rova" />
            </intent-filter>
        </receiver>

        <!-- ADR-0027: daily recording window. Start/Stop are exported=false
             (only the same-UID OS AlarmManager delivers); PendingIntent
             identity uses Intent.data = rova://schedule/{start,stop}. The boot
             receiver is exported=true (the OS sends BOOT_COMPLETED). None of
             these start the camera FGS — checkScheduleReceiverNoFgsStart. -->
        <receiver
            android:name=".service.schedule.ScheduleStartReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.aritr.rova.action.SCHEDULE_WINDOW_START" />
                <data android:scheme="rova" />
            </intent-filter>
        </receiver>
        <receiver
            android:name=".service.schedule.ScheduleStopReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.aritr.rova.action.SCHEDULE_WINDOW_STOP" />
                <data android:scheme="rova" />
            </intent-filter>
        </receiver>
        <receiver
            android:name=".service.schedule.ScheduleBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- FILE PROVIDER -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        
    </application>

</manifest>
