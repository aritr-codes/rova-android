<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto Backup rules for API 23-30 (full-backup-content).
    See ADR 0003 and ROADMAP_v6.md Phase 0 DoD: session segments, manifests,
    and private export temp files must NEVER flow through Auto Backup.

    Domains:
      external  -> getExternalFilesDir() — contains videos/ (segments + manifests)
                   and export/ (Tier 2/3 private temp). Excluded entirely.
      sharedpref-> RovaSettings (user config: interval, duration, presets).
                   Allowed to back up; this is user-facing config, not session state.
-->
<full-backup-content>
    <exclude domain="external" path="." />
</full-backup-content>
