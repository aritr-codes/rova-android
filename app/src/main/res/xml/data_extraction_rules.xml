<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup / restore rules for API 31+ (data-extraction-rules).
    See ADR 0003 and ROADMAP_v6.md Phase 0 DoD: session segments, manifests,
    and private export temp files must NEVER flow through cloud backup OR
    device-to-device transfer.

    cloud-backup     -> Google account auto-backup.
    device-transfer  -> D2D restore on new device setup-wizard.

    Both branches exclude:
      external                       -> getExternalFilesDir (videos/ +
                                        export/ — segments, manifests,
                                        Tier 2/3 temp).
      sharedpref rova_runtime_prefs  -> holds the `mode` key. Excluded so
                                        reinstalls default to Portrait
                                        instead of restoring a prior
                                        PortraitLandscape session. Must
                                        stay in sync with the file name
                                        in RovaSettings.RUNTIME_PREFS_NAME.

    sharedpref rova_settings.xml is allowed to back up (RovaSettings =
    user config: interval, duration, resolution, presets, etc.).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="external" path="." />
        <!-- B5 vault (ADR-0025): explicit vault video-dir exclude (getExternalFilesDir("videos")).
             Redundant with the path="." root exclude, pinned so it survives root narrowing. -->
        <exclude domain="external" path="videos/" />
        <exclude domain="sharedpref" path="rova_runtime_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="external" path="." />
        <!-- B5 vault (ADR-0025): explicit vault video-dir exclude (getExternalFilesDir("videos")). -->
        <exclude domain="external" path="videos/" />
        <exclude domain="sharedpref" path="rova_runtime_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
